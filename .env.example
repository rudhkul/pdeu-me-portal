# Copy this to .env and fill in values
# NEVER commit .env to git — add it to .gitignore

# ── GitHub Data Repository ─────────────────────────────────────────────
# The PRIVATE GitHub repo that stores all faculty data as JSON files
# Create it at github.com → New repository → set Private
VITE_DATA_REPO_OWNER=your-github-org-or-username
VITE_DATA_REPO_NAME=pdeu-me-data

# Fine-grained Personal Access Token (PAT)
# Create at: GitHub → Settings → Developer Settings → Fine-grained tokens
# Set: Repository access → Only "pdeu-me-data"
# Permissions: Contents → Read and Write
VITE_GITHUB_PAT=github_pat_xxxxxxxxxxxxxxxxxxxx

# ── Auth Secret ────────────────────────────────────────────────────────
# Any random string — used to add entropy to password hashes
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_AUTH_SECRET=replace-with-a-long-random-string

# ── EmailJS (free email notifications) ────────────────────────
# Sign up free at https://www.emailjs.com
# Create a service (Gmail), a template, get your keys below
# Set to empty string to disable notifications
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

# Admin email addresses (for notifications)
# These MUST match the fullName in users.json exactly
VITE_ADMIN_EMAIL_Salman=salman@sot.pdpu.ac.in
VITE_ADMIN_EMAIL_Krunal=krunal@sot.pdpu.ac.in
VITE_ADMIN_EMAIL_VivekJaiswal=vivek.jaiswal@sot.pdpu.ac.in
VITE_ADMIN_EMAIL_Anirudh=anirudh.kulkarni@sot.pdpu.ac.in
VITE_ADMIN_EMAIL_Abhinaya=abhinaya.srinivas@sot.pdpu.ac.in
